{
  "name": "aavak-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
    "build": "vite build && cp instrument.server.mjs dist/server",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "deploy": "pnpm run build && wrangler deploy",
    "start": "node --import ./dist/server/instrument.server.mjs dist/server/index.mjs"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.13.8",
    "@hookform/resolvers": "5.2.1",
